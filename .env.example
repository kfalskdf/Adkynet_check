# =============================================================================
# CF Tunnel 监控配置示例
# 复制此文件内容到青龙面板创建环境变量
# =============================================================================

# ========== Cloudflare 配置 ==========
# Cloudflare API Token (需要 Zero Trust Tunnels:Read 权限)
CLOUDFLARE_API_TOKEN=

# Cloudflare Account ID (Dashboard -> 概述页可查看)
CLOUDFLARE_ACCOUNT_ID=

# Tunnel UUID (Dashboard -> 网络 -> Tunnels 可查看)
CLOUDFLARE_TUNNEL_ID=

# ========== Adkynet 配置 (用户名相同，密码不同) ==========
# 用户名 (manager 和 panel 使用相同)
ADKYNET_USER=

# manager.adkynet.com 的密码
MANAGER_PASS=

# panel.adkynet.com 的密码
PANEL_PASS=

# ========== Gotify 配置 ==========
GOTIFY_URL=https://gotify.example.com
GOTIFY_TOKEN=